# ============================================================
# AI驱动动态表单 - 环境变量配置
# ============================================================
# 复制此文件为 .env，然后填入实际值
# cp .env.example .env
# ============================================================

# ---- LLM 配置 ----
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# ---- 数据库配置 ----
DATABASE_URL=sqlite:///./backend/form.db

# ---- Redis（可选）----
REDIS_URL=redis://redis:6379/0

# ---- Neo4j（可选）----
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ---- 应用配置 ----
DEBUG=false
PORT=6173