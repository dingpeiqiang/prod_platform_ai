{
  "formCode": "validation_demo",
  "formName": "校验规则演示",
  "description": "演示各种校验规则的使用",
  "entities": [
    {
      "entityCode": "basic",
      "entityName": "基础校验",
      "fields": [
        {
          "fieldCode": "username",
          "fieldName": "用户名",
          "fieldType": "input",
          "required": true,
          "ruleDescription": "3-20个字符"
        },
        {
          "fieldCode": "age",
          "fieldName": "年龄",
          "fieldType": "number",
          "required": true,
          "ruleDescription": "18-100之间的整数"
        },
        {
          "fieldCode": "password",
          "fieldName": "密码",
          "fieldType": "input",
          "required": true,
          "ruleDescription": "至少8位，必须包含大小写字母和数字"
        }
      ]
    },
    {
      "entityCode": "format",
      "entityName": "格式校验",
      "fields": [
        {
          "fieldCode": "email",
          "fieldName": "邮箱",
          "fieldType": "email",
          "required": true
        },
        {
          "fieldCode": "phone",
          "fieldName": "手机号",
          "fieldType": "phone",
          "required": true
        },
        {
          "fieldCode": "idCard",
          "fieldName": "身份证号",
          "fieldType": "input",
          "required": false,
          "ruleDescription": "18位身份证号，最后一位可以是X"
        },
        {
          "fieldCode": "website",
          "fieldName": "个人网站",
          "fieldType": "input",
          "required": false,
          "ruleDescription": "以http://或https://开头的合法URL"
        }
      ]
    },
    {
      "entityCode": "enum_date",
      "entityName": "枚举和日期",
      "fields": [
        {
          "fieldCode": "department",
          "fieldName": "部门",
          "fieldType": "select",
          "required": true,
          "enumConfig": {
            "type": "static",
            "options": [
              {
                "value": "技术部",
                "label": "技术部"
              },
              {
                "value": "产品部",
                "label": "产品部"
              },
              {
                "value": "运营部",
                "label": "运营部"
              },
              {
                "value": "市场部",
                "label": "市场部"
              }
            ]
          }
        },
        {
          "fieldCode": "startDate",
          "fieldName": "开始日期",
          "fieldType": "date",
          "required": true,
          "ruleDescription": "不早于2024-01-01"
        },
        {
          "fieldCode": "endDate",
          "fieldName": "结束日期",
          "fieldType": "date",
          "required": true,
          "ruleDescription": "不晚于2025-12-31，且必须晚于开始日期"
        }
      ]
    },
    {
      "entityCode": "custom",
      "entityName": "自定义校验",
      "fields": [
        {
          "fieldCode": "evenNumber",
          "fieldName": "偶数",
          "fieldType": "number",
          "required": true,
          "ruleDescription": "必须是偶数"
        },
        {
          "fieldCode": "strongPassword",
          "fieldName": "强密码",
          "fieldType": "input",
          "required": true,
          "ruleDescription": "至少12位，包含大小写字母和数字"
        }
      ]
    }
  ]
}
