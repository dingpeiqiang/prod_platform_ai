{
  "formCode": "sales_order",
  "formName": "销售订单",
  "description": "销售订单表单",
  "entities": [
    {
      "entityCode": "customer",
      "entityName": "客户",
      "fields": [
        {
          "fieldCode": "customer_name",
          "fieldName": "客户姓名",
          "fieldType": "input",
          "required": true,
          "ruleDescription": "至少2个字符"
        },
        {
          "fieldCode": "customer_phone",
          "fieldName": "客户电话",
          "fieldType": "phone",
          "required": true,
          "ruleDescription": "11位中国大陆手机号，以1开头"
        }
      ]
    },
    {
      "entityCode": "order",
      "entityName": "订单",
      "fields": [
        {
          "fieldCode": "order_amount",
          "fieldName": "订单金额",
          "fieldType": "number",
          "required": true,
          "ruleDescription": "正数，最小0.01，最大9999999.99"
        },
        {
          "fieldCode": "order_date",
          "fieldName": "订单日期",
          "fieldType": "date",
          "required": true
        },
        {
          "fieldCode": "remark",
          "fieldName": "备注",
          "fieldType": "textarea",
          "required": false
        }
      ]
    }
  ]
}
