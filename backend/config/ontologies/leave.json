{
  "formCode": "leave",
  "formName": "请假申请",
  "description": "请假申请表单",
  "entities": [
    {
      "entityCode": "applicant",
      "entityName": "申请人",
      "fields": [
        {
          "fieldCode": "applicant_name",
          "fieldName": "申请人姓名",
          "fieldType": "input",
          "required": true,
          "ruleDescription": "2-20个字符"
        },
        {
          "fieldCode": "department",
          "fieldName": "部门",
          "fieldType": "select",
          "required": true,
          "enumConfig": {
            "type": "static",
            "options": [
              {
                "value": "tech",
                "label": "技术部"
              },
              {
                "value": "sales",
                "label": "销售部"
              },
              {
                "value": "finance",
                "label": "财务部"
              },
              {
                "value": "hr",
                "label": "人事部"
              },
              {
                "value": "marketing",
                "label": "市场部"
              }
            ]
          }
        }
      ]
    },
    {
      "entityCode": "leave_info",
      "entityName": "请假信息",
      "fields": [
        {
          "fieldCode": "leave_type",
          "fieldName": "请假类型",
          "fieldType": "select",
          "required": true,
          "enumConfig": {
            "type": "static",
            "options": [
              {
                "value": "annual",
                "label": "年假"
              },
              {
                "value": "sick",
                "label": "病假"
              },
              {
                "value": "personal",
                "label": "事假"
              },
              {
                "value": "marriage",
                "label": "婚假"
              },
              {
                "value": "maternity",
                "label": "产假"
              }
            ]
          }
        },
        {
          "fieldCode": "start_date",
          "fieldName": "开始日期",
          "fieldType": "date",
          "required": true,
          "ruleDescription": "不早于当天前30天，不晚于当天后90天"
        },
        {
          "fieldCode": "end_date",
          "fieldName": "结束日期",
          "fieldType": "date",
          "required": true,
          "ruleDescription": "必须晚于或等于开始日期，且请假天数不超过30天"
        },
        {
          "fieldCode": "reason",
          "fieldName": "请假原因",
          "fieldType": "textarea",
          "required": true,
          "ruleDescription": "5-500个字符"
        }
      ]
    }
  ]
}
