{
  "formCode": "external_api_demo",
  "formName": "外部API调用演示",
  "description": "演示外部API配置化调用",
  "entities": [
    {
      "entityCode": "enum_api",
      "entityName": "枚举API演示",
      "fields": [
        {
          "fieldCode": "department",
          "fieldName": "部门（静态枚举）",
          "fieldType": "select",
          "required": true,
          "enumConfig": {
            "type": "static",
            "options": ["技术部", "产品部", "运营部", "市场部"]
          }
        },
        {
          "fieldCode": "city",
          "fieldName": "城市（API枚举）",
          "fieldType": "select",
          "required": true,
          "enumConfig": {
            "type": "api",
            "api": {
              "url": "https://api.example.com/cities",
              "method": "GET",
              "headers": {
                "Authorization": "Bearer ${token}"
              },
              "timeout": 10,
              "dataPath": "data.cities",
              "cacheTTL": 3600,
              "retryCount": 2,
              "fallback": ["北京", "上海", "广州", "深圳"]
            }
          }
        }
      ]
    },
    {
      "entityCode": "validate_api",
      "entityName": "校验API演示",
      "fields": [
        {
          "fieldCode": "username",
          "fieldName": "用户名",
          "fieldType": "input",
          "required": true,
          "ruleDescription": "至少3个字符，仅支持字母、数字和下划线"
        },
        {
          "fieldCode": "idCard",
          "fieldName": "身份证号",
          "fieldType": "input",
          "required": true,
          "ruleDescription": "18位身份证号，最后一位可以是X"
        }
      ]
    },
    {
      "entityCode": "submit_api",
      "entityName": "提交API演示",
      "fields": [
        {
          "fieldCode": "orderNo",
          "fieldName": "订单号",
          "fieldType": "input",
          "required": true,
          "ruleDescription": "订单号格式：ORD-开头，后跟8位数字，如ORD-20240001"
        },
        {
          "fieldCode": "amount",
          "fieldName": "金额",
          "fieldType": "number",
          "required": true,
          "ruleDescription": "正数，最大9999999.99"
        }
      ]
    }
  ],
  "submitConfig": {
    "type": "api",
    "api": {
      "url": "https://api.example.com/submit/order",
      "method": "POST",
      "headers": {
        "Content-Type": "application/json",
        "X-API-Key": "your-api-key"
      },
      "timeout": 30,
      "dataPath": ""
    }
  }
}
