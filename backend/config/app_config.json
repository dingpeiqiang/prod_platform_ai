{
  "app": {
    "name": "AI驱动动态表单底层框架",
    "version": "2.0.0",
    "debug": true
  },
  "llm": {
    "enabled": true,
    "provider": "custom",
    "model": "qwen-plus-2025-07-28",
    "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
    "apiKey": "sk-16f6fcbc5d1e47f4b976ed8c757ddb95",
    "thinking": true,
    "temperature": 0.5,
    "maxTokens": 4096,
    "maxInputTokens": 180000,
    "fallbackToRules": false,
    "bufferSize": 20,
    "flushInterval": 0.05
  },
  "features": {
    "enableHotReload": true,
    "enableCache": true,
    "cacheTTL": 3600
  },
  "logging": {
    "level": "DEBUG",
    "enableConsole": true,
    "enableFile": false,
    "filePath": "app/logs/app.log",
    "llmCallLogger": {
      "enableConsole": true,
      "enableFile": false,
      "enableDetailedRequest": true,
      "enableDetailedResponse": true,
      "maxPromptPreview": 500,
      "maxResponsePreview": 1000,
      "maxHistory": 1000
    },
    "modules": {
      "llm_service": "DEBUG",
      "chat_api": "DEBUG",
      "llm.minimax": "DEBUG",
      "config_loader": "INFO",
      "agent_executor": "INFO",
      "form_service": "INFO",
      "uvicorn.access": "WARNING",
      "httpx": "WARNING"
    }
  },
  "recommendation": {
    "countScoreWeight": 0.4,
    "userScoreWeight": 0.4,
    "timeScoreWeight": 0.2,
    "countScorePerUnit": 0.1,
    "userScorePerUnit": 0.2,
    "timeDecayDays": 30,
    "historyQueryLimit": 1000,
    "recommendationLimit": 3,
    "confidenceThreshold": 0.4,
    "enableSmartFilter": true
  },
  "smartRecommend": {
    "enableRuleInference": true,
    "enableStaticFallback": true,
    "enableHistoryInference": true,
    "maxRecommendationsPerField": 5
  },
  "sceneRecognition": {
    "defaultScene": "generic"
  },
  "fieldExtraction": {
    "separators": ["是", "为", "：", ":", " "]
  }
}
